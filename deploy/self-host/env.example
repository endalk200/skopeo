# Required. Use the same SemVer for both application images.
SKOPEO_VERSION=0.2.0

# Optional. To pin immutable digests, uncomment both values and use
# compose.yaml together with compose.digest.yaml as documented.
# SKOPEO_API_DIGEST=sha256:<digest from the matching GitHub Release>
# SKOPEO_WEB_DIGEST=sha256:<digest from the matching GitHub Release>

# Required. Public hostname handled by Caddy, for example skopeo.example.com.
SKOPEO_HOST=

# Required. Generate a unique, URL-safe raw password.
POSTGRES_PASSWORD=
# Required. Replace the placeholder with the same password in this connection string.
DATABASE_URL=postgres://skopeo:<same-password>@postgres:5432/skopeo

# Optional. When absent, the API keeps console logging and does not export OTLP.
# OTLP_BASE_URL=https://otel-collector.example.com:4318
