{
	"name": "@skopeo/utils",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"development": "./src/index.ts",
			"node": "./dist/index.js",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"format": "biome check --write --linter-enabled=false package.json tsconfig.json src",
		"format:check": "biome check --linter-enabled=false package.json tsconfig.json src",
		"lint": "biome lint package.json tsconfig.json src",
		"lint:fix": "biome lint --write package.json tsconfig.json src",
		"test": "vitest run src --passWithNoTests"
	},
	"devDependencies": {
		"@skopeo/typescript-config": "workspace:*",
		"@types/node": "^26.1.1",
		"typescript": "6.0.3",
		"vitest": "^4.1.10",
		"@effect/opentelemetry": "4.0.0-beta.98",
		"@effect/platform-node": "4.0.0-beta.98",
		"@effect/vitest": "4.0.0-beta.98",
		"effect": "4.0.0-beta.98"
	}
}
