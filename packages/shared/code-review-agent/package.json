{
	"name": "@skopeo/code-review-agent",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"development": "./src/index.ts",
			"node": "./dist/index.js",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"format": "biome check --write --linter-enabled=false package.json tsconfig.json src",
		"format:check": "biome check --linter-enabled=false package.json tsconfig.json src",
		"lint": "biome lint package.json tsconfig.json src",
		"lint:fix": "biome lint --write package.json tsconfig.json src",
		"test": "vitest run src --passWithNoTests"
	},
	"devDependencies": {
		"@skopeo/typescript-config": "workspace:*",
		"@types/node": "^26.1.1",
		"@effect/vitest": "4.0.0-beta.97",
		"typescript": "7.0.2",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@effect/opentelemetry": "4.0.0-beta.97",
		"@opentelemetry/api": "^1.9.1",
		"@skopeo/tools": "workspace:*",
		"@tanstack/ai": "^0.40.0",
		"@tanstack/ai-anthropic": "^0.16.1",
		"@tanstack/ai-openai": "^0.16.0",
		"effect": "4.0.0-beta.97",
		"zod": "^4.4.3"
	}
}
