{
	"name": "@skopeo/providers",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"development": "./src/index.ts",
			"node": "./dist/index.js",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"format": "biome format --write package.json tsconfig.json src",
		"format:check": "biome format package.json tsconfig.json src",
		"lint": "biome check package.json tsconfig.json src",
		"lint:fix": "biome check --fix package.json tsconfig.json src",
		"test": "vitest run src --passWithNoTests"
	},
	"dependencies": {
		"@skopeo/config": "workspace:*",
		"@tanstack/ai": "^0.40.0",
		"@tanstack/ai-anthropic": "^0.16.1",
		"@tanstack/ai-openai": "^0.16.0",
		"@tanstack/ai-openrouter": "^0.15.8",
		"effect": "4.0.0-beta.94"
	},
	"devDependencies": {
		"@effect/vitest": "4.0.0-beta.94",
		"@skopeo/typescript-config": "workspace:*",
		"@types/node": "^26.1.1",
		"typescript": "6.0.3",
		"vitest": "^4.1.10"
	}
}
