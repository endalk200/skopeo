{
	"name": "@skopeo/code-review-agent",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"development": "./src/index.ts",
			"node": "./dist/index.js",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"format": "biome format --write package.json tsconfig.json src",
		"format:check": "biome format package.json tsconfig.json src",
		"lint": "biome check package.json tsconfig.json src",
		"lint:fix": "biome check --fix package.json tsconfig.json src",
		"test": "vitest run src --passWithNoTests"
	},
	"devDependencies": {
		"@skopeo/typescript-config": "workspace:*",
		"@types/node": "^25.9.3",
		"@effect/vitest": "4.0.0-beta.83",
		"typescript": "6.0.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@effect/opentelemetry": "4.0.0-beta.83",
		"@opentelemetry/api": "^1.9.1",
		"@skopeo/tools": "workspace:*",
		"@tanstack/ai": "^0.29.0",
		"@tanstack/ai-openai": "^0.14.2",
		"effect": "4.0.0-beta.83",
		"zod": "^4.4.3"
	}
}
