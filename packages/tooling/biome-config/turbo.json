{
	"$schema": "https://turborepo.dev/schema.json",
	"extends": ["//"],
	"tags": ["tooling"],
	"tasks": {
		"format:check": {
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/biome.json",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/scripts/**",
				"$TURBO_ROOT$/turbo.json"
			]
		},
		"lint": {
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/biome.json",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/scripts/**",
				"$TURBO_ROOT$/turbo.json"
			]
		}
	}
}
