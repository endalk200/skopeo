{
	"name": "@skopeo/cli",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"bin": {
		"skopeo": "./dist/bin.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"format": "biome format --write package.json tsconfig.json src",
		"format:check": "biome format package.json tsconfig.json src",
		"lint": "biome check package.json tsconfig.json src",
		"lint:fix": "biome check --fix package.json tsconfig.json src",
		"test": "vitest run src --passWithNoTests"
	},
	"dependencies": {
		"@effect/opentelemetry": "4.0.0-beta.70",
		"@effect/platform-node": "4.0.0-beta.70",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/api-logs": "^0.218.0",
		"@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
		"@opentelemetry/resources": "^2.7.1",
		"@opentelemetry/sdk-logs": "^0.218.0",
		"@opentelemetry/sdk-trace-base": "^2.7.1",
		"@opentelemetry/sdk-trace-node": "^2.7.1",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@skopeo/config": "workspace:*",
		"effect": "4.0.0-beta.70"
	},
	"devDependencies": {
		"@ai-sdk/devtools": "^0.0.18",
		"@effect/vitest": "4.0.0-beta.70",
		"@skopeo/typescript-config": "workspace:*",
		"@types/node": "^25.9.1",
		"ai": "^6.0.189",
		"typescript": "6.0.3",
		"vitest": "^4.1.7"
	}
}
