{
	"$schema": "https://turborepo.dev/schema.json",
	"extends": ["//"],
	"tags": ["app-cli"],
	"tasks": {
		"build": {
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/scripts/build-cli.ts",
				"$TURBO_ROOT$/scripts/sync-cli-version.ts"
			]
		},
		"cli:dev": {
			"passThroughEnv": [
				"AI_SDK_DEVTOOLS",
				"ANTHROPIC_API_KEY",
				"GITHUB_*",
				"OPENAI_API_KEY",
				"OPENROUTER_API_KEY",
				"SKOPEO_*"
			]
		}
	}
}
