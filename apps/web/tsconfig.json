{
	"extends": "@skopeo/typescript-config/base.json",
	"compilerOptions": {
		"plugins": [{ "name": "next" }],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"allowJs": true,
		"noEmit": true,
		"incremental": true,
		"declaration": false,
		"declarationMap": false,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules", ".next"]
}
