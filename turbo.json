{
	"$schema": "https://v2-9-14.turborepo.dev/schema.json",
	"globalDependencies": [
		"scripts/**",
		"biome.json",
		"apps/*/biome.json",
		"apps/*/turbo.json",
		"packages/biome-config/**",
		"packages/typescript-config/**"
	],
	"ui": "stream",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"dependsOn": ["^lint:fix"]
		},
		"test": {
			"dependsOn": ["^test"]
		},
		"test:integration": {
			"cache": false,
			"dependsOn": ["^test:integration"]
		},
		"format": {
			"dependsOn": ["^format"]
		},
		"format:check": {
			"dependsOn": ["^format:check"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		}
	}
}
