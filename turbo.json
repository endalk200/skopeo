{
	"$schema": "https://v2-9-14.turborepo.dev/schema.json",
	"globalDependencies": [
		"scripts/**",
		"biome.json",
		"apps/*/biome.json",
		"apps/*/turbo.json",
		"packages/tooling/biome-config/**",
		"packages/tooling/typescript-config/**"
	],
	"ui": "stream",
	"boundaries": {
		"tags": {
			"app-api": {
				"dependencies": {
					"allow": ["api", "shared", "tooling"]
				}
			},
			"app-cli": {
				"dependencies": {
					"allow": ["cli", "shared", "tooling"]
				}
			},
			"app-web": {
				"dependencies": {
					"allow": ["web", "shared", "tooling"]
				}
			},
			"api": {
				"dependencies": {
					"allow": ["api", "shared", "tooling"]
				}
			},
			"cli": {
				"dependencies": {
					"allow": ["cli", "shared", "tooling"]
				}
			},
			"shared": {
				"dependencies": {
					"allow": ["shared", "tooling"]
				}
			},
			"tooling": {
				"dependencies": {
					"allow": ["tooling"]
				}
			},
			"web": {
				"dependencies": {
					"allow": ["web", "shared", "tooling"]
				}
			}
		}
	},
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"dependsOn": ["^lint:fix"]
		},
		"test": {
			"dependsOn": ["^test"]
		},
		"test:integration": {
			"cache": false,
			"dependsOn": ["^test:integration"]
		},
		"format": {
			"dependsOn": ["^format"]
		},
		"format:check": {
			"dependsOn": ["^format:check"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		}
	}
}
