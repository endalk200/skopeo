{
	"$schema": "https://turborepo.dev/schema.json",
	"concurrency": "4",
	"globalPassThroughEnv": ["CI"],
	"ui": "stream",
	"boundaries": {
		"tags": {
			"app-api": {
				"dependencies": {
					"allow": ["api", "shared", "tooling"]
				}
			},
			"app-cli": {
				"dependencies": {
					"allow": ["cli", "shared", "tooling"]
				}
			},
			"app-web": {
				"dependencies": {
					"allow": ["web", "shared", "tooling"]
				}
			},
			"api": {
				"dependencies": {
					"allow": ["api", "shared", "tooling"]
				}
			},
			"cli": {
				"dependencies": {
					"allow": ["cli", "shared", "tooling"]
				}
			},
			"shared": {
				"dependencies": {
					"allow": ["shared", "tooling"]
				}
			},
			"tooling": {
				"dependencies": {
					"allow": ["tooling"]
				}
			},
			"web": {
				"dependencies": {
					"allow": ["web", "shared", "tooling"]
				}
			}
		}
	},
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"check-types": {
			"dependsOn": ["transit"]
		},
		"cli:dev": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"format": {
			"cache": false
		},
		"format:check": {
			"inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.json"]
		},
		"lint": {
			"dependsOn": ["transit"],
			"inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/biome.json"]
		},
		"lint:fix": {
			"cache": false
		},
		"start": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["transit"]
		},
		"test:compose": {
			"cache": false,
			"passThroughEnv": [
				"COMPOSE_PROJECT_NAME",
				"DATABASE_URL",
				"POSTGRES_PASSWORD",
				"SKOPEO_HOST",
				"SKOPEO_VERSION"
			]
		},
		"test:integration": {
			"cache": false
		},
		"transit": {
			"dependsOn": ["^transit"]
		}
	}
}
